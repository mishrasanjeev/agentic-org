# C6Z local runtime vertical demo environment template.
# Copy to .env.c6z.local for local runs. The .env.c6z.local file is ignored.

SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-04
SHOPIFY_WEBHOOK_SECRET=

GRANTEX_COMMERCE_BASE_URL=http://localhost:8080
GRANTEX_COMMERCE_INTERNAL_TOKEN=

PLURAL_PINE_CLIENT_ID=
PLURAL_PINE_CLIENT_SECRET=
# Optional. Defaults to sandbox and the Plural/Pine sandbox base URL.
PLURAL_PINE_ENVIRONMENT=sandbox
PLURAL_PINE_BASE_URL=
PLURAL_PINE_CAPABILITY_URL=
