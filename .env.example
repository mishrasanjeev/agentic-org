# AgentFlow OS — Environment Variables Reference
# Copy to .env and fill in values. Never commit .env to version control.

# LLM
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
AGENTFLOW_LLM_PRIMARY=claude-3-5-sonnet-20241022
AGENTFLOW_LLM_FALLBACK=gpt-4o-2024-11-20
AGENTFLOW_LLM_TEMPERATURE=0.2

# Infrastructure
AGENTFLOW_DB_URL=postgresql+asyncpg://user:pass@host:5432/agentflow
AGENTFLOW_REDIS_URL=redis://host:6379/0
# Object Storage (Google Cloud Storage or S3-compatible)
AGENTFLOW_STORAGE_BUCKET=agentflow-docs-prod
AGENTFLOW_STORAGE_REGION=asia-south1
AGENTFLOW_STORAGE_ENDPOINT=  # Leave empty for GCS; set for MinIO/S3-compat
AGENTFLOW_SECRET_KEY=change-me-to-32-char-random-string

# Auth
AGENTFLOW_AUTH_PROVIDER=grantex
GRANTEX_CLIENT_ID=gx_prod_...
GRANTEX_CLIENT_SECRET=
GRANTEX_TOKEN_SERVER=https://auth.yourorg.com
AGENTFLOW_JWT_PUBLIC_KEY_URL=https://auth.yourorg.com/.well-known/jwks.json
AGENTFLOW_TOKEN_TTL_MINUTES=60

# Observability
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=agentflow-production
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.yourorg.com
OTEL_SERVICE_NAME=agentflow-core

# Notifications
SLACK_BOT_TOKEN=xoxb-...
SLACK_HITL_CHANNEL=#hitl-approvals
SENDGRID_API_KEY=SG....
HITL_NOTIFICATION_EMAIL=ops@yourorg.com

# Platform
AGENTFLOW_ENV=production
AGENTFLOW_LOG_LEVEL=INFO
AGENTFLOW_PII_MASKING=true
AGENTFLOW_DATA_REGION=IN
AGENTFLOW_AUDIT_RETENTION_YEARS=7
AGENTFLOW_MAX_CONCURRENT_WORKFLOWS=500
AGENTFLOW_DEFAULT_HITL_THRESHOLD_INR=500000
AGENTFLOW_DEFAULT_CONFIDENCE_FLOOR=0.88
AGENTFLOW_MAX_AGENT_RETRIES=3
AGENTFLOW_CORS_ALLOWED_ORIGINS=https://app.agentflow.yourdomain.com  # Comma-separated; empty=allow all in dev

# Connectors
DARWINBOX_API_KEY=
DARWINBOX_BASE_URL=https://yourorg.darwinbox.in/api
ORACLE_FUSION_URL=https://yourorg.oraclecloud.com
ORACLE_FUSION_USERNAME=
ORACLE_FUSION_PASSWORD=
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_API_TOKEN=
GSTN_GSP_API_KEY=
GSTN_DSC_PATH=/secrets/gstn_dsc.p12
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
AHREFS_API_TOKEN=
PINELABS_PLURAL_API_KEY=
PINELABS_PLURAL_API_SECRET=
BANKING_AA_CLIENT_ID=
BANKING_AA_CLIENT_SECRET=
