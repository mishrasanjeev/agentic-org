# AgenticOrg — Environment Variables Reference
# Copy to .env and fill in values. Never commit .env to version control.

# LLM — Gemini Flash (free) is default. Get key at https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=AIza...                      # Required (free at aistudio.google.com)
ANTHROPIC_API_KEY=                                  # Optional — enable when switching to Claude
OPENAI_API_KEY=                                     # Optional — enable for GPT-4o fallback
AGENTICORG_LLM_PRIMARY=gemini-2.5-flash             # Free tier: 15 RPM, 1M tokens/day
AGENTICORG_LLM_FALLBACK=gemini-2.5-flash-preview-05-20       # Free tier: lighter model as fallback
AGENTICORG_LLM_TEMPERATURE=0.2
AGENTICORG_LLM_ROUTING=auto                          # auto | tier1 | tier2 | tier3 | disabled
AGENTICORG_LLM_MODE=cloud                            # cloud | local | auto (local=Ollama/vLLM air-gapped)
# Smart routing tiers (auto mode picks best tier per query):
#   Tier 1: Gemini 2.5 Flash (free) — simple lookups, formatting
#   Tier 2: Gemini 2.5 Pro — analysis, summarization
#   Tier 3: Claude Opus / GPT-4o — complex reasoning, legal, financial
# Air-gapped overrides (when LLM_MODE=local):
# AGENTICORG_LOCAL_TIER1=llama3.2:3b                  # Ollama small model
# AGENTICORG_LOCAL_TIER2=llama3.1:8b                  # Ollama medium model
# AGENTICORG_LOCAL_TIER3=llama3.1:70b                 # vLLM large model
# OLLAMA_HOST=http://localhost:11434                   # Ollama server URL
# VLLM_API_BASE=http://localhost:8000/v1               # vLLM server URL
# To switch to Claude later: AGENTICORG_LLM_PRIMARY=claude-sonnet-4-20250514

# Infrastructure
AGENTICORG_DB_URL=postgresql+asyncpg://user:pass@host:5432/agenticorg
AGENTICORG_REDIS_URL=redis://host:6379/0
# Object Storage (Google Cloud Storage or S3-compatible)
AGENTICORG_STORAGE_BUCKET=agenticorg-docs-prod
AGENTICORG_STORAGE_REGION=asia-south1
AGENTICORG_STORAGE_ENDPOINT=  # Leave empty for GCS; set for MinIO/S3-compat
AGENTICORG_SECRET_KEY=change-me-to-32-char-random-string

# Auth
AGENTICORG_AUTH_PROVIDER=grantex
# Enforce Redis-backed auth state across replicas (Codex K-E). When "1",
# token blacklist + login throttle refuse to degrade to per-pod memory.
# REQUIRED for enterprise multi-replica deploys; leave unset for
# single-replica dev/local testing.
AGENTICORG_AUTH_STATE_STRICT=1
GRANTEX_API_KEY=gx_key_...                          # Required — Grantex SDK API key for enforce() and manifest loading
GRANTEX_BASE_URL=https://api.grantex.dev             # Optional — Grantex API base URL (default: https://api.grantex.dev)
GRANTEX_CLIENT_ID=gx_prod_...
GRANTEX_CLIENT_SECRET=
GRANTEX_TOKEN_SERVER=https://auth.yourorg.com
GRANTEX_MANIFESTS_DIR=./manifests                    # Optional — directory for custom connector manifests (JSON/YAML)
AGENTICORG_JWT_PUBLIC_KEY_URL=https://auth.yourorg.com/.well-known/jwks.json
AGENTICORG_TOKEN_TTL_MINUTES=60

# Observability
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=agenticorg-production
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.yourorg.com
OTEL_SERVICE_NAME=agenticorg-core

# Notifications
SLACK_BOT_TOKEN=xoxb-...
SLACK_HITL_CHANNEL=#hitl-approvals
SENDGRID_API_KEY=SG....
HITL_NOTIFICATION_EMAIL=ops@yourorg.com

# Platform
AGENTICORG_APP_URL=https://app.agenticorg.com        # Base URL for the app (used in payment callbacks, portal return URLs)
AGENTICORG_ENV=production
AGENTICORG_LOG_LEVEL=INFO
AGENTICORG_PII_MASKING=true
AGENTICORG_PII_REDACTION_MODE=before_llm       # before_llm | logs_only | disabled
AGENTICORG_DATA_REGION=IN
AGENTICORG_AUDIT_RETENTION_YEARS=7
AGENTICORG_MAX_CONCURRENT_WORKFLOWS=500
AGENTICORG_DEFAULT_HITL_THRESHOLD_INR=500000
AGENTICORG_DEFAULT_CONFIDENCE_FLOOR=0.88
AGENTICORG_MAX_AGENT_RETRIES=3
AGENTICORG_CORS_ALLOWED_ORIGINS=https://app.agenticorg.yourdomain.com  # Comma-separated; empty=allow all in dev

# Connectors
DARWINBOX_API_KEY=
DARWINBOX_BASE_URL=https://yourorg.darwinbox.in/api
ORACLE_FUSION_URL=https://yourorg.oraclecloud.com
ORACLE_FUSION_USERNAME=
ORACLE_FUSION_PASSWORD=
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_API_TOKEN=
GSTN_GSP_API_KEY=
GSTN_DSC_PATH=/secrets/gstn_dsc.p12
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
HUBSPOT_ACCESS_TOKEN=
GOOGLE_ADS_DEVELOPER_TOKEN=
AHREFS_API_TOKEN=
PLURAL_CLIENT_ID=                                   # PineLabs Plural OAuth client ID
PLURAL_CLIENT_SECRET=                                # PineLabs Plural OAuth client secret
PLURAL_WEBHOOK_SECRET=                               # PineLabs Plural webhook secret (base64-encoded)
PLURAL_ENV=sandbox                                   # sandbox | production
PLURAL_CALLBACK_URL=https://app.agenticorg.com/api/v1/billing/callback
BANKING_AA_CLIENT_ID=
BANKING_AA_CLIENT_SECRET=

# Composio — 1000+ tool marketplace (MIT). Get key at https://app.composio.dev
COMPOSIO_API_KEY=                                   # Optional — enables Composio tool marketplace

# RAGFlow — Knowledge Base / RAG engine (Apache 2.0). Upload docs, agents query via semantic search
RAGFLOW_API_URL=http://localhost:9380               # RAGFlow instance URL
RAGFLOW_API_KEY=                                    # RAGFlow API key

# LiveKit — Voice Agents (Apache 2.0). Real-time voice AI with telephony/SIP support
LIVEKIT_URL=ws://localhost:7880                     # LiveKit server URL
LIVEKIT_API_KEY=                                    # LiveKit API key
LIVEKIT_API_SECRET=                                 # LiveKit API secret

# Stripe — Billing for hosted tier (global). Self-hosted is free forever
STRIPE_SECRET_KEY=sk_...                            # Stripe secret key for subscription billing
STRIPE_WEBHOOK_SECRET=whsec_...                     # Stripe webhook signing secret
STRIPE_PRICE_PRO=price_...                          # Stripe Price ID for Pro plan ($99/mo)
STRIPE_PRICE_ENTERPRISE=price_...                   # Stripe Price ID for Enterprise plan ($499/mo)
STRIPE_CALLBACK_URL=https://app.agenticorg.com/api/v1/billing/callback/stripe

# Microsoft 365 — Bot Framework / MS Teams integration
MICROSOFT_APP_ID=                                   # Microsoft Bot Framework App ID
MICROSOFT_APP_SECRET=                               # Microsoft Bot Framework App Secret

# Content Safety — toxicity detection on LLM-generated content
TOXICITY_THRESHOLD=0.7                              # Toxicity score threshold (0.0-1.0), above = blocked
CONTENT_SAFETY_ENABLED=true                         # Enable/disable content safety checks
