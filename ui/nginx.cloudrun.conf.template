    set $csp_jsonld_hashes_2 "'sha256-M/MeI+MYe3Vg16SQIt4CDEWOvnoi4JvhJH1fflLfaQM=' 'sha256-Tj3C2whYZVhL0G67TIu5cMDEFx6SQyMZDsGYbfZ/cxM=' 'sha256-H1h+SudiXOLcb+fHbuW8P7Rx3RD5WN993Oj89vqMseY=' 'sha256-j8eWZ4AxacBSIpi8qrvi8aeA38svn74FCCQDI+lb0xk=' 'sha256-xm65+tEZvs9WP0mxVJJtQHBirA11OFuS2PLM7r2AwfY=' 'sha256-IzBjBL1K+BBXHkqi/NaBOPQ0tojr2iYV00z2N9yMXzU=' 'sha256-ZQM3BDDZLxBfbMb9z6LoWS0rcRCHaw9af5qRUHQZKxI=' 'sha256-jOIOsz3MQZL7ibkN/2jFHl6IB9sB758KIkQ3yzz0vJI=' 'sha256-pk6FKLyQtFdDe9zveCVz7AMWaUOZaG5SJB9hyBOEqMw=' 'sha256-yhhfTV3QWJ9Wy50wpeevT/Dtlu4LN0PeULEFmndZVGo=' 'sha256-A6s3gfZ5HApPVrTixnyNn9AAbOMFLHvBhLOLNzHmu7c=' 'sha256-BBSniPmUKoz0V7ihsXHUXOIOgx22HLpTZRdGGJZo/6A=' 'sha256-3KQENBIFamzDSl+sflQcyiVJZPPxXOaVXidAdkSEKNY=' 'sha256-U3cu1ExEsI0VR83eEU98NNoGdx2KrhYrI+RYnJClrSM=' 'sha256-B5/+/Aiiu97qoy+RML6dV6neGUWW6nIDDEimXM2dXUA=' 'sha256-QJKDGUtF3nFtjwTVQWG8MLcfR35h2TslLbZlFCi12Q8=' 'sha256-8oni1wTWLefD5Xuq1FJwir7isE0BxEnu62qeLyk0fJc=' 'sha256-R7XRunwi3HJN12oClq8icmXdomSqXqX55+uk+OYQA3A=' 'sha256-J4km6nZoDcsan9VAkkwgTCtLDddFBpv1vpQdX3jpzPU=' 'sha256-sQFC7gbgeRXwSzN02ug/8zkR2nZJR/8DBa9rULltWMc=' 'sha256-2K+s/zWsXOxACbDviTNckxTwNCQ0fo8zfH5o0btXjFY=' 'sha256-OBTihVctqnvYxYdp6cXWhH1/A+J90MLtqdfOwFUmxHA=' 'sha256-Jnoc8UsCL2Dl36VMEMT6HghyABhQx0xERIbZT1lzy3c=' 'sha256-H+JwTt41IstR4mR4AJckYXeLWCW5APMOkoCCfaH71u4=' 'sha256-nfEj01NHzv3yrfOZp6rUKe5uHdU5pQu4Zo86/eufrOk=' 'sha256-bSPKGZkIhXih4lq2jtZwvSjVjhfCrHcMkgQW6amgT3s=' 'sha256-0cfXRm90HL7uj4WlZNri+/RYf2ornxFCjV1pNMNZD60=' 'sha256-Z7uHoNEoGFta9ddy8LglqZ6bbwPTSRjht3ODyE0fsS0=' 'sha256-ABV2h3kqKCDY8/Fmx8h0sEJhbHfpWjTQtms0x6TIiac=' 'sha256-L1TvOpihxrQYnQl0Fr5q1B37pfZ73ctPn8vfbDjBVMM=' 'sha256-sjghSYYnLnW84FqpdxeCAap5IsFg1b5nen3PgsqgooI=' 'sha256-yAeDSYqs6gFBixRxoFNbcnyuSqmqUdVxfFf0TbcINjA=' 'sha256-Gs6yhLjPc1ylJ8e3yOSGP4iMSUzFEyZAJAA3etbesU8=' 'sha256-1Qlu5mOvy1zj6BaVZi1LmCjCrbihBNroyxROoeHe/qQ=' 'sha256-yUrR4/i6nOPZYlFLBcYr2O3sAvOIXLjBkKHQiDR4pbo='";
