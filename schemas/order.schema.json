{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Sales Order",
  "type": "object",
  "required": [
    "order_id",
    "type",
    "customer_id",
    "line_items",
    "total"
  ],
  "properties": {
    "order_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "sales",
        "purchase"
      ]
    },
    "customer_id": {
      "type": "string"
    },
    "line_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "quantity": {
            "type": "number"
          },
          "unit_price": {
            "type": "number"
          },
          "amount": {
            "type": "number"
          }
        }
      }
    },
    "subtotal": {
      "type": "number"
    },
    "tax": {
      "type": "number"
    },
    "total": {
      "type": "number"
    },
    "payment_status": {
      "type": "string",
      "enum": [
        "unpaid",
        "partial",
        "paid",
        "refunded"
      ]
    },
    "fulfilment_status": {
      "type": "string",
      "enum": [
        "pending",
        "processing",
        "shipped",
        "delivered",
        "cancelled"
      ]
    }
  }
}