# SEC-010: production base images pinned by digest. Refresh via
# scripts/refresh_image_digests.sh after a Renovate/Dependabot bump.
# node:26-slim @ 2026-05-01
FROM node:26-slim@sha256:ffc78385a788964bb3cbab5e434ff79a10bdc25b8ae6db03fe5fe6cb14053c09 AS builder
WORKDIR /app
COPY ui/package.json ui/package-lock.json ./
RUN npm ci --no-audit --no-fund
ARG CACHE_BUST=1
COPY ui/ .
# Copy backend source for llms.txt/sitemap generators (they parse agents + connectors)
COPY pyproject.toml README.md ../
COPY core/billing/catalog.py ../core/billing/catalog.py
COPY core/agents/ ../core/agents/
COPY connectors/ ../connectors/
ARG VITE_GA4_ID=""
ENV VITE_GA4_ID=$VITE_GA4_ID
RUN npm run build

# nginx:alpine @ 2026-05-01
FROM nginx:alpine@sha256:54f2a904c251d5a34adf545a72d32515a15e08418dae0266e23be2e18c66fefa
COPY --from=builder /app/dist /usr/share/nginx/html
COPY ui/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=3s CMD wget -q --spider http://localhost/ || exit 1
