    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Task latency distribution (p50, p90, p99) by domain and agent type",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 5,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "pluginVersion": "10.2.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum(rate(agenticorg_task_latency_seconds_bucket{tenant=~\"$tenant\", domain=~\"$domain\"}[5m])) by (le, domain))",
          "legendFormat": "p50 — {{domain}}",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.90, sum(rate(agenticorg_task_latency_seconds_bucket{tenant=~\"$tenant\", domain=~\"$domain\"}[5m])) by (le, domain))",
          "legendFormat": "p90 — {{domain}}",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(agenticorg_task_latency_seconds_bucket{tenant=~\"$tenant\", domain=~\"$domain\"}[5m])) by (le, domain))",
          "legendFormat": "p99 — {{domain}}",
          "refId": "C"
        }
      ],
      "title": "Task Latency (p50 / p90 / p99)",
      "type": "timeseries"
    },
